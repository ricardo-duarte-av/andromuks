# Release signing credentials — copy to `keystore.properties` (gitignored) for local release builds.
# In CI these come from GitHub Secrets (see .github/workflows), not this file.
# Debug builds do NOT need any of these.

# Path to the keystore, relative to the app module (app/). Defaults to gomuks.keystore if unset.
KEYSTORE_FILE=gomuks.keystore
KEYSTORE_PASSWORD=changeme
KEY_ALIAS=habitica
KEY_PASSWORD=changeme
